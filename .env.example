# ==================== 阿里云 DashScope AI 配置 ====================
# 必填：DashScope API Key（从百炼控制台获取）
QWEN_API_KEY=your_dashscope_api_key_here

# 可选：轻量模型（用于路由与闲聊）
# QWEN_MODEL_LIGHT=qwen-flash

# 可选：专业模型（用于深度回答）
# QWEN_MODEL_PRO=qwen-plus

# 可选：API 超时设置（秒）
# QWEN_TIMEOUT_CONNECT=20
# QWEN_TIMEOUT_READ=90

# ==================== 嵌入与向量库配置 ====================
# 嵌入模型（阿里云 DashScope）
# EMBEDDING_MODEL=text-embedding-v2

# Chroma 向量数据库持久化目录
# CHROMA_PERSIST_DIR=./chroma_db

# ==================== 联网搜索配置（阿里云 AI 搜索开放平台） ====================
# 必填：搜索 API Key（从搜索开放平台控制台获取）
WEB_SEARCH_API_KEY=your_search_api_key_here

# 必填：搜索服务域名（不含协议头，例如 default-xxx.platform-cn-shanghai.opensearch.aliyuncs.com）
WEB_SEARCH_HOST=your_host_here

# ==================== 其他可选配置 ====================
# 调试模式（true / false）
# DEBUG=false

# 日志级别（DEBUG / INFO / WARNING / ERROR）
# LOG_LEVEL=INFO

# SQLite 数据库文件路径
# DB_FILE=qa_data.db

# AI 请求频率限制（每分钟最大请求数）
# RATE_LIMIT_AI_MAX=10
# RATE_LIMIT_AI_WINDOW=60